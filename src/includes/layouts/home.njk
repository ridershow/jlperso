---
layout: base
---

<!-- banner -->
<div class="ds-banner">
    <div class="container">
        <div class="row">
            <div class="col-12 col-sm-12 col-md-5 col-lg-5 col-xl-5 col-xxl-5">
                <figure>
                    <picture>
                        <img src="/assets/images/profile-image.webp" alt="" loading="lazy">
                    </picture>
                </figure>
            </div>
            <div class="col-12 col-sm-12 col-md-7 col-lg-7 col-xl-7 col-xxl-7">
                <section>
                    <h1>
                        <span>HI THERE</span> {{ site.tagline | safe }}
                    </h1>
                    <ul class="ds-numbervalulist">
                        <li>
                            <strong>2012</strong>
                            <span>First website</span>
                        </li>
                        <li>
                            <strong>32</strong>
                            <span>Clients I worked with</span>
                        </li>
                        <li>
                            <strong>∞</strong>
                            <span>Love for what I do</span>
                        </li>
                    </ul>
                </section>
            </div>
        </div>
    </div>
</div>
<!-- banner -->

<!-- about -->
<div class="ds-about-section">
    <div class="container">
        <section>
            <h2 class="ds-heading">About Me</h2>
            <p>Invente, design, prototype, industrialize.<br> Originally shaped as industrial and mechanical designer applying it for 2 years in the car manufacturing industry, I rapidly took my way off into the extreme sport industry. From there I started
                building for a freestyle scooter brand and a media company. Working from 3D design to manufacturing at large scale to building brand identity through photography alongside team &amp; travel management. These experiences have enlightened
                my love for marketing which got me into Growth Marketing. It enables me to pursue this willingness to constantly Invente, design, prototype, industrialize. But in the tech world now!</p>
            <div class="ds-button-sec text-center">
                <a href="/assets/pdf/Resume-Jeremy-Lanfranchi.pdf" class="ds-button">Download Resume</a>
            </div>
        </section>
    </div>
</div>
<!-- about -->

<!-- Skills -->
<div class="ds-skills-section">
    <div class="container">
        <div class="row">
            <div class="col-12 col-sm-12 col-md-6 col-lg-6 col-xl-6 col-xxl-6">
                <h2 class="ds-heading">Core Skills</h2>
                <ul class="ds-skills-list">
                    <li>Search Ads</li>
                    <li>Social Ads</li>
                    <li>SEO</li>
                    <li>ABM</li>
                    <li>Google Spreadsheet</li>
                    <li>Google Analytics</li>
                    <li>Webflow</li>
                    <li>Github</li>
                    <li>HTML</li>
                    <li>CSS</li>
                    <li>Figma</li>
                    <li>Adobe Photoshop</li>
                    <li>Adobe Lightroom</li>
                </ul>
            </div>
            <div class="col-12 col-sm-12 col-md-6 col-lg-6 col-xl-6 col-xxl-6">
                <h2 class="ds-heading">Other Skills</h2>
                <ul class="ds-skills-list">
                    <li>Google Data Studio</li>
                    <li>Content marketing</li>
                    <li>Email marketing</li>
                    <li>Copywriting</li>
                    <li>Creativity</li>
                    <li>UX</li>
                    <li>Responsive Web Design</li>
                    <li>Web Scraping</li>
                    <li>Javascript</li>
                    <li>Davinci Resolve</li>
                </ul>
            </div>
        </div>
    </div>
</div>
<!-- Skills -->

<!-- Experience -->
<div class="ds-experience-section">
    <div class="container">
        <h2 class="ds-heading">Work Experiences</h2>
        <div class="row ds-experience-list">
            <div class="row justify-content-center">
                <div class="col-12 col-sm-12 col-md-10 col-lg-8 col-xl-8 col-xxl-8">
                    <div class="ds-investment-list-section">
                        <div class="row">
                            {% for exp in site.work_experiences %}
                                {% include "components/experience.njk" %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Experience -->

<!-- Works -->
<div class="ds-work-section">
    <div class="container">
        <h2 class="ds-heading">Latest works</h2>
        {% for work in site.works %}
            {% include "components/work.njk" %}
        {% endfor %}
    </div>
</div>
<!-- Works -->
